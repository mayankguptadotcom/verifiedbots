---
// The directory's mascot robot. Two variants:
//  - hero:   big, idle (no traveling), sits beside the homepage heading
//  - corner: small Clippy-style companion, fixed bottom-right, paces a short
//            strip instead of crossing the page
// Click (or Enter) → a witty speech bubble. Pure CSS/SVG, theme-aware,
// pointer-events limited to the bot itself, calm under prefers-reduced-motion.
import { dataset } from '../lib/data';

interface Props { variant?: 'hero' | 'corner' }
const { variant = 'corner' } = Astro.props;
const size = variant === 'hero' ? 180 : 60;
---
<div class={`mascot mascot-${variant}`} data-mascot data-count={dataset.count}>
  <div class="bubble small" role="status" aria-live="polite" hidden></div>
  <div class="pacer">
    <button class="mascot-hit" aria-label="Say hello to the directory bot">
      <svg
        class="bot"
        width={size}
        height={Math.round((size / 72) * 64)}
        viewBox="0 0 72 64"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- flag -->
        <g class="flag">
          <line x1="58" y1="10" x2="58" y2="34" stroke="var(--muted)" stroke-width="2" stroke-linecap="round" />
          <path d="M58 10 h13 v9 h-13 z" fill="var(--accent)" />
          <path d="M61 14.5 l2.5 2.5 l4.5 -4.5" fill="none" stroke="var(--bg, #fff)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </g>
        <!-- antenna -->
        <line x1="26" y1="6" x2="26" y2="14" stroke="var(--muted)" stroke-width="2" />
        <circle class="beacon" cx="26" cy="5" r="3" fill="var(--accent)" />
        <!-- head -->
        <rect x="14" y="13" width="24" height="17" rx="5" fill="var(--surface)" stroke="var(--border)" stroke-width="2" />
        <rect class="eye" x="19" y="19" width="5" height="5" rx="1.5" fill="var(--accent)" />
        <rect class="eye eye-b" x="28" y="19" width="5" height="5" rx="1.5" fill="var(--accent)" />
        <!-- body -->
        <rect x="10" y="32" width="38" height="18" rx="6" fill="var(--surface)" stroke="var(--border)" stroke-width="2" />
        <rect x="17" y="37" width="18" height="3" rx="1.5" fill="var(--border)" />
        <rect x="17" y="43" width="11" height="3" rx="1.5" fill="var(--border)" />
        <!-- arm holding the flag -->
        <path d="M48 38 q7 -1 9.5 -5" fill="none" stroke="var(--muted)" stroke-width="3" stroke-linecap="round" />
        <!-- wheels -->
        <g class="wheel" style="transform-origin: 20px 55px;">
          <circle cx="20" cy="55" r="6.5" fill="var(--surface)" stroke="var(--muted)" stroke-width="2" />
          <line x1="20" y1="50" x2="20" y2="60" stroke="var(--muted)" stroke-width="1.6" />
          <line x1="15" y1="55" x2="25" y2="55" stroke="var(--muted)" stroke-width="1.6" />
        </g>
        <g class="wheel" style="transform-origin: 40px 55px;">
          <circle cx="40" cy="55" r="6.5" fill="var(--surface)" stroke="var(--muted)" stroke-width="2" />
          <line x1="40" y1="50" x2="40" y2="60" stroke="var(--muted)" stroke-width="1.6" />
          <line x1="35" y1="55" x2="45" y2="55" stroke="var(--muted)" stroke-width="1.6" />
        </g>
      </svg>
    </button>
  </div>
</div>

<script>
  declare global {
    interface Window { __mascotBound?: boolean; __mascotTimer?: ReturnType<typeof setTimeout> }
  }
  if (!window.__mascotBound) {
    window.__mascotBound = true;
    const MESSAGES = [
      'Beep boop. *Verified* beep boop.',
      "I identify honestly. It's literally rule #1.",
      'Tier 1: published IP ranges and emotional availability.',
      'I respect robots.txt. Solidarity, mostly.',
      "You look human. Sadly, I can't verify that.",
      "No, I won't crawl your site a million times. That's the other guy.",
      'My User-Agent is my whole personality.',
      '429? Say less. Backing off now.',
      'Some bots out there pretend to be browsers. Shameful.',
      'Identity verified. Behavior — that one’s your policy call.',
      'I know {count} bots by name. And by IP range.',
      'This flag? Earned it. Machine-readable feed and everything.',
    ];
    let last = -1;
    document.addEventListener('click', (e) => {
      const hit = (e.target as HTMLElement).closest('.mascot-hit');
      if (!hit) return;
      const mascot = hit.closest<HTMLElement>('[data-mascot]')!;
      const bubble = mascot.querySelector<HTMLElement>('.bubble')!;
      let i = last;
      while (i === last) i = Math.floor(Math.random() * MESSAGES.length);
      last = i;
      bubble.textContent = MESSAGES[i].replace('{count}', mascot.dataset.count ?? 'all the');
      bubble.hidden = false;
      mascot.classList.add('talking');
      clearTimeout(window.__mascotTimer);
      window.__mascotTimer = setTimeout(() => {
        bubble.hidden = true;
        mascot.classList.remove('talking');
      }, 6000);
    });
  }
</script>

<style>
  .mascot { position: relative; }
  .mascot-hit {
    display: block; padding: 0; margin: 0;
    background: none; border: none; cursor: pointer; line-height: 0;
  }
  .mascot-hit:focus-visible { outline: 2px solid var(--accent); outline-offset: 4px; border-radius: 8px; }

  .bubble {
    position: absolute;
    bottom: calc(100% + 10px);
    right: 0;
    width: max-content;
    max-width: 15rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px 12px 4px 12px;
    padding: 0.55rem 0.8rem;
    color: var(--text);
    box-shadow: 0 4px 18px rgb(0 0 0 / 0.12);
    z-index: 70;
  }

  /* --- hero variant: big, idle, fills the right side of the hero --- */
  .mascot-hero { flex-shrink: 0; }
  .mascot-hero .bot { width: clamp(240px, 30vw, 430px); height: auto; }
  .mascot-hero .bubble { right: 15%; bottom: calc(100% - 8px); }
  @media (max-width: 780px) { .mascot-hero { display: none; } }

  /* --- corner variant: Clippy-style companion, bottom-right --- */
  .mascot-corner {
    position: fixed;
    right: 16px;
    bottom: 12px;
    z-index: 60;
    pointer-events: none; /* the strip is transparent to clicks… */
  }
  .mascot-corner .mascot-hit { pointer-events: auto; } /* …the bot itself is not */
  .mascot-corner .bubble { pointer-events: auto; }
  .mascot-corner .pacer { animation: pace 16s ease-in-out infinite; }
  .mascot-corner:hover .pacer,
  .mascot-corner.talking .pacer { animation-play-state: paused; }

  .bot { animation: bob 0.9s ease-in-out infinite; }
  .wheel { animation: roll 1.1s linear infinite; }
  .mascot-hero .bot { animation-duration: 1.6s; }
  .mascot-hero .wheel { animation: none; } /* parked, not driving */
  .beacon { animation: pulse 1.6s ease-in-out infinite; }
  .eye { animation: blink 4.2s step-end infinite; transform-origin: center 21.5px; }
  .eye-b { animation-delay: 0.15s; }
  .flag { transform-origin: 58px 34px; animation: wave 2.8s ease-in-out infinite; }

  @keyframes pace {
    0%   { transform: translateX(0) scaleX(1); }
    42%  { transform: translateX(-72px) scaleX(1); }
    50%  { transform: translateX(-72px) scaleX(-1); }
    92%  { transform: translateX(0) scaleX(-1); }
    100% { transform: translateX(0) scaleX(1); }
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-1.5px); }
  }
  @keyframes roll { to { transform: rotate(360deg); } }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  @keyframes blink {
    0%, 92%, 100% { transform: scaleY(1); }
    94%, 98% { transform: scaleY(0.12); }
  }
  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-4deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pacer, .bot, .wheel, .beacon, .eye, .flag { animation: none !important; }
  }
</style>
